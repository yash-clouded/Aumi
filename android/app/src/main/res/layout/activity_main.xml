<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal"
    android:background="#F9F9F9">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Aumi"
        android:textSize="32sp"
        android:fontFamily="sans-serif-black"
        android:textColor="#1A1A1A"
        android:layout_marginTop="48dp" />

    <TextView
        android:id="@+id/txt_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Not Paired"
        android:textColor="#666666"
        android:layout_marginTop="8dp" />

    <androidx.camera.view.PreviewView
        android:id="@+id/preview_view"
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_marginTop="24dp"
        android:visibility="gone" />

    <ImageView
        android:id="@+id/img_qr"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_marginTop="48dp"
        android:visibility="gone" />

    <Button
        android:id="@+id/btn_pair"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="Pair with Mac"
        android:textAllCaps="false"
        android:layout_marginTop="48dp"
        android:backgroundTint="#007AFF"
        android:textColor="#FFFFFF" />

    <Button
        android:id="@+id/btn_mirror"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="Mirror to Mac"
        android:textAllCaps="false"
        android:layout_marginTop="16dp"
        android:backgroundTint="#EDEDED"
        android:textColor="#333333" />

    <Button
        android:id="@+id/btn_enable_calls"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="Enable Calls on Mac (set default Phone app)"
        android:textAllCaps="false"
        android:layout_marginTop="16dp"
        android:backgroundTint="#EDEDED"
        android:textColor="#333333"
        android:visibility="gone" />

</LinearLayout>
